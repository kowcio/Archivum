{
  "name": "vue-project",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wxt -b chrome --mv3",
    "build": "wxt build -b chrome --mv3 && wxt build -b firefox --mv3",
    "zip": "wxt zip -b chrome --mv3",
    "postinstall": "wxt prepare",
    "build-only": "wxt build -b chrome --mv3",
    "extension:build": "wxt build -b chrome --mv3",
    "extension:run": "wxt -b chrome --mv3",
    "extension:dev": "wxt -b chrome --mv3",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test:unit": "vitest --run",
    "test": "npm run test:unit --run && npm run test:playwright:ui ",
    "test:unit:watch": "vitest",
    "test:playwright": "npx playwright test test/playwright",
    "test:playwright:firefox": "npx playwright test test/playwright --project firefox-mv3",
    "test:playwright:chromium": "npx playwright test test/playwright --project chrome-mv3",
    "test:playwright:debug": "npm run build && npx playwright test test/playwright --project chrome-mv3-debug",
    "test:playwright:ui": "npx playwright test test/playwright --ui --project chrome-mv3",
    "test:playwright:ui:firefox": "npx playwright test test/playwright --ui --project firefox-mv3",
    "ci": "npm run type-check && npm run test:unit && npm run build",
    "extension:package": "npm run build && npm run zip"
  },
  "dependencies": {
    "@quasar/extras": "1.17.0",
    "@vueuse/core": "^13.5.0",
    "axios": "^1.13.4",
    "dayjs": "^1.11.18",
    "pinia": "^3.0.3",
    "quasar": "^2.18.2",
    "vue": "^3.5.17",
    "vue-chartjs": "^5.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.57.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.2.2",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/eslint-plugin": "^1.2.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "archiver": "^5.3.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.57.0",
    "prettier": "3.5.3",
    "typescript": "^5.8.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-plugin-web-extension": "4.5.0",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.2",
    "web-ext": "^8.3.0",
    "wxt": "^0.20.13"
  }
}
