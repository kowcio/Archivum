{
  "name": "vue-project",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@} --clean --verbose\" --",
    "watch": "tsc-watch --pretty --onEmitDebounceMs 5000 --onSuccess \"npm run build\" --onFailure \"echo Beep! Compilation Failed\"",
    "preview": "vite preview",
    "test:unit": "vitest --run --coverage",
    "test:playwright": "npm run build && npx playwright test src/test/playwright --headed --workers=1",
    "test:playwright:no-build": "npx playwright test src/test/playwright --workers=1",
    "test:playwright:ui": "npx playwright test src/test/playwright --workers=1 --ui --project firefox-mv2",
    "playwright:install": "npx playwright install",
    "extension:build": "vite build",
    "extension:package": "node scripts/package-xpi.js",
    "prepare:firefox-profile": "node scripts/prepare-firefox-profile.js",
    "test:playwright:dist": "set PLAYWRIGHT_TEST_MODE=dist && npm run extension:build && npx playwright test test/playwright --headed --workers=1",
    "postinstall": "npx playwright install chromium firefox",
    "build-only": "vite build",
    "build2": "vite build --outDir dis --include src/**/*.{js,ts,vue} --verbose",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@quasar/vite-plugin": "^1.9.0",
    "@quasar/extras": "1.17.0",
    "@vueuse/core": "^13.5.0",
    "@vueuse/nuxt": "^13.5.0",
    "dayjs": "^1.11.18",
    "pinia": "^3.0.3",
    "axios": "^1.4.0",
    "vue": "^3.5.17",
    "vue-router": "^4.5.1",
    "vue-chartjs": "^5.2.0"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^25.0.6",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/eslint-plugin": "^1.2.7",
    "@vitest/coverage-v8": "^4.0.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "@playwright/test": "^1.57.0",
    "playwright": "^1.57.0",
    "@pinia/testing": "^1.0.3",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.5.3",
    "rollup-plugin-copy": "3.5.0",
    "start-server-and-test": "^2.0.12",
    "tsc-watch": "^7.1.1",
    "typescript": "^5.8.0",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-plugin-web-extension": "4.5.0",
    "vitest": "^4.0.16",
    "vue-tsc": "^3.2.2",
    "axios-mock-adapter": "^2.1.0"
    ,"archiver": "^5.3.1"
  }
}
