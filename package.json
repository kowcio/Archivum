{
  "name": "vue-project",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "wxt -b chrome --mv3",
    "build": "wxt build -b chrome --mv3 && wxt build -b firefox --mv3",
    "zip": "wxt zip -b chrome --mv3",
    "postinstall": "wxt prepare && npx playwright install chromium firefox",
    "build-only": "wxt build -b chrome --mv3",
    "extension:build": "wxt build -b chrome --mv3",
    "extension:run": "wxt -b chrome --mv3",
    "extension:dev": "wxt -b chrome --mv3",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "npm run test:unit --run && npm run test:playwright:chromium",
    "test:unit": "vitest --run",
    "test:unit:watch": "vitest",
    "test:playwright": "npm run test:playwright:chromium",
    "test:playwright:chromium": "npx playwright test src/test/playwright --project chrome-mv3",
    "test:playwright:debug": "npm run build && npx playwright test src/test/playwright --project chrome-mv3-debug",
    "test:playwright:ui": "npx playwright test src/test/playwright --ui --project chrome-mv3",
    "ci": "npm run type-check && npm run test:unit && npm run build",
    "extension:package": "npm run build && npm run zip"
  },
  "dependencies": {
    "@quasar/extras": "1.17.0",
    "@vueuse/core": "^13.5.0",
    "axios": "^1.16.1",
    "dayjs": "^1.11.20",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "vue": "^3.5.34",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.60.0",
    "@tsconfig/node22": "^22.0.5",
    "@quasar/vite-plugin": "^1.11.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.8.0",
    "@types/webextension-polyfill": "^0.12.4",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/eslint-plugin": "^1.2.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "@wxt-dev/module-vue": "^1.0.3",
    "archiver": "^5.3.1",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.57.0",
    "prettier": "3.5.3",
    "typescript": "^5.8.0",
    "vite": "^8.0.13",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-web-extension": "4.5.1",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.9",
    "web-ext": "^10.1.0",
    "wxt": "^0.20.26"
  }
}