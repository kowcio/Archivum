{
  "description": "Adds a solid red border to all webpages matching mozilla.org.",
  "name": "Czynsz_FF_estate_care",
  "version": "1.0.0",
  "homepage_url": "https://github.com/kowcio",
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "browserExtensionTemplate@Kowalski"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png"
  },
  "manifest_version": 2,
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "browserExtensionTemplate",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "chrome_url_overrides": {},
  "permissions": [
    "tabs",
    "activeTab",
    "bookmarks",
    "clipboardRead",
    "storage"
  ]
}