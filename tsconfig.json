{
  "compilerOptions": {
    // Module settings
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    // Emit settings
    "noEmit": true,
    // Interop and compatibility
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    // Type checking - Strict mode for quality
    "strict": true,
    "skipLibCheck": true,
    // Global types
    "types": ["node", "chrome"],
    // Path aliases
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "wxt/*": ["./.wxt/*"]
    }
  },
  "include": [
    "env.d.ts",
    "src/**/*",
    "wxt.config.ts",
    ".wxt/wxt.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".output",
    "test"
  ]
}
