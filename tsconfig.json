{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.vitest.json"
    },
    {
      "path": "./tsconfig.playwright.json"
    }
  ],
  "compilerOptions": {
    // Module settings - Common for all sub-configs
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    // Emit settings
    "noEmit": true,

    // Interop and compatibility
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // Type checking - Strict mode for quality
    "strict": true,
    "skipLibCheck": true,

    // Global types
    "types": ["firefox-webext-browser"]
  }
}
