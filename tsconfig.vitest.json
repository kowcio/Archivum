{
  "extends": "./tsconfig.app.json",
  "include": [
    "src/**/*",
    "src/**/*.spec.ts",
    "src/**/*.spec.vue",
    "test/unit/**/*"
  ],
  "exclude": [
    "test/playwright/**/*"
  ],
  "compilerOptions": {
    // Inherits from root via tsconfig.app.json: target, module, moduleResolution,
    // esModuleInterop, forceConsistentCasingInFileNames, strict, skipLibCheck
    "noEmit": true,

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "lib": [],

    // Test-specific types (includes vite/client for import.meta.env)
    "types": ["node", "jsdom", "vitest/globals", "vite/client"],

    // Path aliases (extends tsconfig.app.json paths + src alias for tests)
    "paths": {
      "@/*": ["./src/*"],
      "src/*": ["./src/*"],
      "wxt/*": ["./.wxt/*"]
    }
  }
}

