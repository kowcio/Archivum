{
  "extends": "./tsconfig.app.json",
  "include": [
    "src/**/*",
    "src/**/*.spec.ts",
    "src/**/*.spec.vue"
  ],
  "exclude": [
    "src/test/playwright/**/*"
  ],
  "compilerOptions": {
    // Inherits from root via tsconfig.app.json: target, module, moduleResolution,
    // noEmit, esModuleInterop, forceConsistentCasingInFileNames, strict, skipLibCheck

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "composite": true,
    "lib": [],

    // Test-specific types
    "types": ["node", "jsdom", "vitest/globals"]
  }
}

