{
  "extends": "./tsconfig.app.json",
  "include": [
    "src/**/*",
    "src/**/*.spec.ts",
    "src/**/*.spec.vue"
  ],
  "exclude": [
    "src/test/playwright/**/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "composite": true,
    "lib": [],
    "skipLibCheck": true,
    "types": [
      "node",
      "jsdom",
      "vitest/globals"
    ]
  }
}