{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/**/*.js",
    "src/**/*.html",
    ".wxt/wxt.d.ts"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "test/**/*"
  ],
  "compilerOptions": {
    // Inherits from root: target, module, moduleResolution,
    // esModuleInterop, forceConsistentCasingInFileNames, strict, skipLibCheck
    "noEmit": true,

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "resolveJsonModule": true,

    // Path aliases
    "paths": {
      "@/*": ["./src/*"],
      "wxt/*": ["./.wxt/*"]
    },

    // Additional types for app code
    "types": ["wxt"]
  }
}

