{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/**/*.js",
    "src/**/*.html",
    "entrypoints/**/*",
    ".wxt/wxt.d.ts"
  ],
  "exclude": [
    "src/**/__tests__/*",
    "src/test/**/*"
  ],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "wxt/*": [
        "./.wxt/*"
      ]
    },
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["wxt"]
  }
}