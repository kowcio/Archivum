{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    "wxt.config.*",
    "web-ext.config.*",
    "vite.config.*",
    "vitest.config.*",
    "nightwatch.conf.*",
    "playwright.config.*",
    "eslint.config.*",
    "test/playwright/**/*.ts",
    "test/playwright/**/*.js",
    "test/playwright/**/*.ts",
    "test/playwright/**/*.js"
  ],
  "compilerOptions": {
    // Inherits from root: target, module, moduleResolution,
    // esModuleInterop, forceConsistentCasingInFileNames, strict, skipLibCheck
    "noEmit": true,

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",

    // Additional types for build tools
    "types": ["node", "@playwright/test", "wxt", "chrome"],

    // Extra strict checks for build scripts
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  }
}
